generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  age           Int
  email         String         @unique
  passwordHash  String         @map("password_hash")
  role          UserRole       @default(USER)
  preferredTheme String       @default("cyan") @map("preferred_theme")
  bio           String? 
  registrations Registration[]
  sessions      Session[]
  payments      Payment[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
}

model ContactMessage {
  id          Int      @id @default(autoincrement())
  fullName    String   @map("full_name")
  email       String
  dateOfBirth DateTime @map("date_of_birth")
  message     String
  createdAt   DateTime @default(now()) @map("created_at")
}

model Team {
  id            Int            @id @default(autoincrement())
  teamName      String         @unique @map("team_name")
  game          String
  captain       String
  players       Player[]
  registrations Registration[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  rank      String
  image     String
  game      String
  score     Int
  teamId    Int?     @map("team_id")
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
}

model Tournament {
  id              Int            @id @default(autoincrement())
  title           String         @unique
  game            String
  scheduledAt     DateTime       @map("scheduled_at")
  timeLabel       String         @map("time_label")
  maxParticipants Int            @default(10) @map("max_participants")
  registrations   Registration[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")
}

model Registration {
  id           Int                @id @default(autoincrement())
  playerName   String             @map("player_name")
  gameId       String             @map("game_id")
  teamName     String             @map("team_name")
  status       RegistrationStatus @default(PENDING)
  userId       Int?               @map("user_id")
  teamId       Int?               @map("team_id")
  tournamentId Int?               @map("tournament_id")
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  team         Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tournament   Tournament?        @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @default(now()) @updatedAt @map("updated_at")
  payment      Payment?

  @@index([tournamentId])
  @@index([teamId])
  @@index([userId])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id             Int           @id @default(autoincrement())
  userId         Int?          @map("user_id")
  registrationId Int?          @unique @map("registration_id")
  amountCents    Int           @map("amount_cents")
  currency       String        @default("USD")
  status         PaymentStatus @default(PAID)
  provider       String        @default("Demo Gateway")
  reference      String        @unique
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
}
